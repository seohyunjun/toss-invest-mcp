# 토스증권 Open API 자격증명
# 토스증권 앱 → 더보기 → Open API → 신청 후 발급받은 값을 채우세요.
# 이 파일을 복사해 .env 로 만들고 실제 값을 넣으세요. (.env 는 git 커밋 금지!)

TOSS_CLIENT_ID=c_xxxxxxxxxxxxxxxxxxxxxxx
TOSS_CLIENT_SECRET=s_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) 계좌/자산/주문 엔드포인트의 기본 계좌 식별자 (정수)
# X-Tossinvest-Account 헤더로 전송됩니다. get_accounts() 로 확인 가능.
TOSS_ACCOUNT_SEQ=

# (선택) MCP 서버 로그 설정
# stdout 은 MCP 프로토콜 전용이라 로그는 stderr 및 아래 파일로만 남습니다.
# TOSS_LOG_LEVEL: DEBUG / INFO(기본) / WARNING / ERROR
# TOSS_LOG_FILE : 지정하면 해당 경로 파일에도 모든 tool 호출/결과/에러를 기록
TOSS_LOG_LEVEL=INFO
TOSS_LOG_FILE=
